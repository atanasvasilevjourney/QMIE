//@version=6
// ════════════════════════════════════════════════════════════════════════
//  QMIE — Visualizer Indicator                                  v2.0
// ════════════════════════════════════════════════════════════════════════
//  Companion to the server-side QMIE Scanner. Open this on any chart
//  and the same scoring math runs locally so the marks you see here
//  match the Discord/Telegram alerts the server fires.
//
//  This is an indicator, NOT a strategy. It does NOT place trades.
//  Manual entry only — that's the whole design.
//
//  Plots:
//    • Supertrend (10/3) primary line, regime-coloured
//    • EMA 200 macro filter
//    • Pivot S/R levels (last 6 each side)
//    • Buy / Sell labels on signal bars
//
//  Dashboard panel:
//    • Per-module score breakdown (ST / EMA / RSI / ADX / HTF / SR / Vol)
//    • Live grade & total score
//    • Distance to nearest S/R in ATR units
//
//  Alerts:
//    • alert.freq_once_per_bar_close — fires only on confirmed bars
//    • JSON payload mirrors `models.TVSignal`
//      so you can wire this to /webhook for redundant alerting
// ════════════════════════════════════════════════════════════════════════
indicator("QMIE Visualizer", shorttitle="QMIE", overlay=true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count  = 200)

// ─── Inputs ────────────────────────────────────────────────────────────
g_core   = "❶ Signal Engine"
g_filter = "❷ Filters"
g_viz    = "❸ Visualization"
g_alert  = "❹ Alerts"

// Weights (must match server config)
wST  = input.int(20, "Supertrend Weight",     group=g_core, minval=0, maxval=100)
wEMA = input.int(15, "EMA200 Weight",         group=g_core, minval=0, maxval=100)
wRSI = input.int(15, "RSI Weight",            group=g_core, minval=0, maxval=100)
wADX = input.int(15, "ADX Weight",            group=g_core, minval=0, maxval=100)
wHTF = input.int(20, "HTF Weight",            group=g_core, minval=0, maxval=100)
wSR  = input.int(10, "S/R Weight",            group=g_core, minval=0, maxval=100)
wVOL = input.int( 5, "Volatility Weight",     group=g_core, minval=0, maxval=100)
wRIB = input.int(10, "EMA Ribbon Weight",     group=g_core, minval=0, maxval=100)
wSTR = input.int(10, "Structure (BOS) Weight",group=g_core, minval=0, maxval=100)
wSWP = input.int( 8, "Liquidity Sweep Weight",group=g_core, minval=0, maxval=100)

minGrade = input.string("A", "Min Alert Grade",
     options=["A+","A","B","C","REJECT"], group=g_alert)

htfRes   = input.timeframe("240", "Higher Timeframe", group=g_filter)
pivotLen = input.int(8,  "Pivot Lookback (left=right)", group=g_filter, minval=2, maxval=30)

minATRpct = input.float(0.10, "Min ATR%", group=g_filter, step=0.05)
maxATRpct = input.float(8.00, "Max ATR%", group=g_filter, step=0.10)

slMult = input.float(1.5, "SL × ATR", group=g_core, step=0.1)
tpMult = input.float(2.5, "TP × ATR", group=g_core, step=0.1)

showST    = input.bool(true,  "Show Supertrend",   group=g_viz)
showEMA   = input.bool(true,  "Show EMA 200",      group=g_viz)
showSR    = input.bool(true,  "Show S/R levels",   group=g_viz)
showLabel = input.bool(true,  "Show signal label", group=g_viz)
showPanel = input.bool(true,  "Show dashboard",    group=g_viz)

emitAlert = input.bool(true, "Emit alert on bar close", group=g_alert)

// ─── Indicator math (Pine v6, all global scope) ────────────────────────
// Triple Supertrend
[st1, dir1] = ta.supertrend(3.0, 10)
[st2, dir2] = ta.supertrend(2.0, 11)
[st3, dir3] = ta.supertrend(1.0, 12)

// Use Pine convention: dir = -1 means uptrend (price > st). Normalise to
// our +1 = up convention to match the server.
toUp(d) => d == -1 ? 1 : -1
d1 = toUp(dir1)
d2 = toUp(dir2)
d3 = toUp(dir3)
agreement = d1 + d2 + d3

// EMA 200 macro filter
ema200 = ta.ema(close, 200)

// RSI
rsiVal  = ta.rsi(close, 14)
rsiPrev = rsiVal[1]

// ATR + ADX (use ta.dmi which returns DI+/DI−/ADX)
atrVal = ta.atr(14)
[plusDI, minusDI, adxVal] = ta.dmi(14, 14)

// HTF data (non-repainting via lookahead_on + [1])
htfClose = request.security(syminfo.tickerid, htfRes, close[1],   lookahead=barmerge.lookahead_on, gaps=barmerge.gaps_off, ignore_invalid_symbol=true)
htfEma   = request.security(syminfo.tickerid, htfRes, ta.ema(close, 200)[1], lookahead=barmerge.lookahead_on, gaps=barmerge.gaps_off, ignore_invalid_symbol=true)

// HTF triple-ST agreement, computed at the HTF context
htfAgreementCalc() =>
    [_l1, dA] = ta.supertrend(3.0, 10)
    [_l2, dB] = ta.supertrend(2.0, 11)
    [_l3, dC] = ta.supertrend(1.0, 12)
    (dA == -1 ? 1 : -1) + (dB == -1 ? 1 : -1) + (dC == -1 ? 1 : -1)

htfDir = request.security(syminfo.tickerid, htfRes, htfAgreementCalc()[1],
     lookahead=barmerge.lookahead_on, gaps=barmerge.gaps_off, ignore_invalid_symbol=true)

// ─── Pivot S/R ─────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,   pivotLen, pivotLen)

var array<float> resLevels = array.new<float>()
var array<float> supLevels = array.new<float>()

// Push new pivots, cap at 6 each
if not na(ph)
    array.unshift(resLevels, ph)
    if array.size(resLevels) > 6
        array.pop(resLevels)
if not na(pl)
    array.unshift(supLevels, pl)
    if array.size(supLevels) > 6
        array.pop(supLevels)

// Distances in ATR (defensive: avoid 0/NaN ATR)
nearestRes() =>
    float best = na
    for i = 0 to array.size(resLevels) - 1
        v = array.get(resLevels, i)
        if v >= close and (na(best) or v < best)
            best := v
    best
nearestSup() =>
    float best = na
    for i = 0 to array.size(supLevels) - 1
        v = array.get(supLevels, i)
        if v <= close and (na(best) or v > best)
            best := v
    best

resPx = nearestRes()
supPx = nearestSup()
dRes  = (not na(resPx) and atrVal > 0) ? (resPx - close) / atrVal : 99.0
dSup  = (not na(supPx) and atrVal > 0) ? (close - supPx) / atrVal : 99.0

// ─── Component scores (mirror server signal_engine.py) ─────────────────
sign(x) => x > 0 ? 1 : x < 0 ? -1 : 0

// 1. Supertrend
// agreement ∈ {-3,-1,+1,+3}: ±3 = all three agree, ±1 = 2/3 majority.
// We score 2/3 partial agreement at 1/3 strength so it isn't dropped.
stD = agreement >=  1 ?  1 : agreement <= -1 ? -1 : 0
stContrib = math.abs(agreement) / 3.0
stScore = math.round(stD * wST * stContrib)

// 2. EMA200
emaDist = math.abs(close - ema200) / ema200 * 50
emaD    = close > ema200 ? 1 : close < ema200 ? -1 : 0
emaC    = math.max(0.5, math.min(1.0, emaDist))
emaScore = math.round(emaD * wEMA * emaC)

// 3. RSI
rsiD = 0
rsiC = 0.0
if rsiVal >= 75
    rsiD := -1
    rsiC := 0.5
else if rsiVal <= 25
    rsiD := 1
    rsiC := 0.5
else if rsiVal > rsiPrev and rsiVal > 45 and rsiVal < 70
    rsiD := 1
    rsiC := 1.0
else if rsiVal < rsiPrev and rsiVal > 30 and rsiVal < 55
    rsiD := -1
    rsiC := 1.0
rsiScore = math.round(rsiD * wRSI * rsiC)

// 4. ADX
adxD = 0
adxC = 0.0
if adxVal >= 25
    adxC := math.min(1.0, adxVal / 50.0)
    adxD := plusDI > minusDI ? 1 : minusDI > plusDI ? -1 : 0
else if adxVal >= 18
    adxC := 0.5
    adxD := plusDI > minusDI ? 1 : minusDI > plusDI ? -1 : 0
adxScore = math.round(adxD * wADX * adxC)

// 5. HTF alignment — partial agreement scaled, matches signal_engine.py
htfAboveEma = htfClose > htfEma
htfD = 0
htfContrib = 0.0
if htfDir >= 1 and htfAboveEma
    htfD := 1
    htfContrib := math.abs(htfDir) / 3.0
else if htfDir <= -1 and not htfAboveEma
    htfD := -1
    htfContrib := math.abs(htfDir) / 3.0
htfScore = math.round(htfD * wHTF * htfContrib)

// 6. S/R room
srD = 0
srC = 0.0
if dRes > dSup
    srD := 1
    srC := math.min(1.0, dRes / 4.0)
    if dRes < 0.3
        srC := srC * 0.3
else if dSup > dRes
    srD := -1
    srC := math.min(1.0, dSup / 4.0)
    if dSup < 0.3
        srC := srC * 0.3
srScore = math.round(srD * wSR * srC)

// 7b. EMA Ribbon (8/21/55/89) — matches ema_ribbon_dir()
e8  = ta.ema(close, 8)
e21 = ta.ema(close, 21)
e55 = ta.ema(close, 55)
e89 = ta.ema(close, 89)
ribD = 0
ribC = 0.0
if e8 > e21 and e21 > e55 and e55 > e89 and close > e8
    ribD := 1
    ribC := 1.0
else if e8 > e21 and e21 > e55 and close > e21
    ribD := 1
    ribC := 0.6
else if close > e55
    ribD := 1
    ribC := 0.3
else if e8 < e21 and e21 < e55 and e55 < e89 and close < e8
    ribD := -1
    ribC := 1.0
else if e8 < e21 and e21 < e55 and close < e21
    ribD := -1
    ribC := 0.6
else if close < e55
    ribD := -1
    ribC := 0.3
ribScore = math.round(ribD * wRIB * ribC)

// 7c. Market Structure — BOS via pivot sequence (matches market_structure_dir())
// Track last 4 pivot highs/lows, check ascending lows (bull) or descending highs (bear)
var float[] pivHi = array.new<float>()
var float[] pivLo = array.new<float>()
pivH2 = ta.pivothigh(high, 5, 5)
pivL2 = ta.pivotlow(low, 5, 5)
if not na(pivH2)
    array.unshift(pivHi, pivH2)
    if array.size(pivHi) > 4
        array.pop(pivHi)
if not na(pivL2)
    array.unshift(pivLo, pivL2)
    if array.size(pivLo) > 4
        array.pop(pivLo)
strD = 0
strC = 0.0
if array.size(pivLo) >= 4
    ascLows = (array.get(pivLo,0) > array.get(pivLo,1) ? 1 : 0) +
              (array.get(pivLo,1) > array.get(pivLo,2) ? 1 : 0) +
              (array.get(pivLo,2) > array.get(pivLo,3) ? 1 : 0)
    if ascLows == 3
        strD := 1
        strC := 1.0
    else if ascLows >= 2
        strD := 1
        strC := 0.5
if array.size(pivHi) >= 4
    descHighs = (array.get(pivHi,0) < array.get(pivHi,1) ? 1 : 0) +
                (array.get(pivHi,1) < array.get(pivHi,2) ? 1 : 0) +
                (array.get(pivHi,2) < array.get(pivHi,3) ? 1 : 0)
    if descHighs == 3
        strD := -1
        strC := 1.0
    else if descHighs >= 2
        strD := -1
        strC := 0.5
strScore = math.round(strD * wSTR * strC)

// 7d. Liquidity Sweep — wick grab of recent swing (matches liquidity_sweep_dir())
swpLow  = ta.lowest(low[1],  20)
swpHigh = ta.highest(high[1], 20)
swpD = 0
swpC = 0.0
// Check last 3 bars
for bi = 1 to 3
    bLow   = low[bi]
    bHigh  = high[bi]
    bClose = close[bi]
    refLow  = ta.lowest(low[bi+1],  20)
    refHigh = ta.highest(high[bi+1], 20)
    if bLow < refLow and bClose > refLow
        swpD := 1
        swpC := 1.0
        break
    if bHigh > refHigh and bClose < refHigh
        swpD := -1
        swpC := 1.0
        break
swpScore = math.round(swpD * wSWP * swpC)

// 7. Volatility regime (additive bonus)
atrPct = (atrVal / close) * 100.0
volBonus = (atrPct >= 0.4 and atrPct <= 4.0) ? wVOL : 0

// ─── Aggregate ─────────────────────────────────────────────────────────
rawSum = stScore + emaScore + rsiScore + adxScore + htfScore + srScore + ribScore + strScore + swpScore
maxDir = wST + wEMA + wRSI + wADX + wHTF + wSR + wRIB + wSTR + wSWP

side    = rawSum > 0 ? "BUY" : rawSum < 0 ? "SELL" : "NEUTRAL"
score0  = math.abs(rawSum) / maxDir * 95.0 + volBonus
score   = math.max(0.0, math.min(100.0, score0))

grade = side == "NEUTRAL" ? "REJECT" :
   score >= 90 ? "A+" :
   score >= 80 ? "A"  :
   score >= 65 ? "B"  :
   score >= 50 ? "C"  : "REJECT"

gradeRank(g) =>
    g == "A+" ? 4 : g == "A" ? 3 : g == "B" ? 2 : g == "C" ? 1 : 0

// Volatility regime gate
volOK = atrPct >= minATRpct and atrPct <= maxATRpct
sigOK = volOK and gradeRank(grade) >= gradeRank(minGrade)

// SL / TP (info only — no orders)
sl = side == "BUY"  ? close - slMult * atrVal :
     side == "SELL" ? close + slMult * atrVal : close
tp = side == "BUY"  ? close + tpMult * atrVal :
     side == "SELL" ? close - tpMult * atrVal : close

// ─── Plots ─────────────────────────────────────────────────────────────
plot(showEMA ? ema200 : na, "EMA 200",   color=color.new(color.orange, 0), linewidth=2)
// EMA Ribbon (8/21/55/89) — always shown when showEMA is on
plot(showEMA ? e8  : na, "EMA 8",  color=color.new(color.green,  20), linewidth=1)
plot(showEMA ? e21 : na, "EMA 21", color=color.new(color.green,  50), linewidth=1)
plot(showEMA ? e55 : na, "EMA 55", color=color.new(color.orange, 40), linewidth=1)
plot(showEMA ? e89 : na, "EMA 89", color=color.new(color.red,    40), linewidth=1)
plot(showST  ? st1    : na, "Supertrend",
     color = d1 == 1 ? color.new(#26a69a, 0) : color.new(#ef5350, 0),
     linewidth = 2)

// S/R lines as thin price-coordinate horizontal lines for the last bar.
// We draw labels on confirmed bars only.
var line[] resLines = array.new<line>()
var line[] supLines = array.new<line>()

clearLines(arr) =>
    for i = 0 to array.size(arr) - 1
        line.delete(array.get(arr, i))
    array.clear(arr)

if showSR and (barstate.islastconfirmedhistory or barstate.islast)
    clearLines(resLines)
    clearLines(supLines)
    for i = 0 to array.size(resLevels) - 1
        v = array.get(resLevels, i)
        ln = line.new(bar_index - 50, v, bar_index + 5, v,
             xloc = xloc.bar_index,
             color = color.new(#ef5350, 30),
             style = line.style_dotted, width = 1)
        array.push(resLines, ln)
    for i = 0 to array.size(supLevels) - 1
        v = array.get(supLevels, i)
        ln = line.new(bar_index - 50, v, bar_index + 5, v,
             xloc = xloc.bar_index,
             color = color.new(#26a69a, 30),
             style = line.style_dotted, width = 1)
        array.push(supLines, ln)

// Signal labels — explicit y so we don't distort overlay axis
prevSide = side[1]
isFreshBuy  = side == "BUY"  and prevSide != "BUY"  and sigOK
isFreshSell = side == "SELL" and prevSide != "SELL" and sigOK

if showLabel and barstate.isconfirmed and isFreshBuy
    label.new(bar_index, low, "▲ " + grade + " " + str.tostring(score, "#"),
         color = color.new(#26a69a, 0),
         textcolor = color.white,
         style = label.style_label_up,
         yloc = yloc.belowbar,
         size = size.small)
if showLabel and barstate.isconfirmed and isFreshSell
    label.new(bar_index, high, "▼ " + grade + " " + str.tostring(score, "#"),
         color = color.new(#ef5350, 0),
         textcolor = color.white,
         style = label.style_label_down,
         yloc = yloc.abovebar,
         size = size.small)

// ─── Dashboard panel ───────────────────────────────────────────────────
color C_BG      = #0f1117
color C_HEADER  = #1e88e5
color C_LABEL   = #6b7280
color C_TEXT    = #e0e0e0
color C_BULL    = #26a69a
color C_BEAR    = #ef5350
color C_NEUTRAL = #2a2d35

var table dash = table.new(position.top_right, 2, 15,
     bgcolor = C_BG, frame_color = C_NEUTRAL, frame_width = 1,
     border_color = C_NEUTRAL, border_width = 1)

cellOf(score, w) =>
    score > 0 ? C_BULL : score < 0 ? C_BEAR : C_NEUTRAL

if showPanel and (barstate.islastconfirmedhistory or barstate.islast)
    table.cell(dash, 0, 0, "QMIE", text_color=color.white, bgcolor=C_HEADER, text_size=size.small)
    table.cell(dash, 1, 0, side + " · " + grade,
         text_color=color.white,
         bgcolor = side == "BUY" ? C_BULL : side == "SELL" ? C_BEAR : C_NEUTRAL,
         text_size=size.small)

    table.cell(dash, 0, 1, "Score",        text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(score, "#.0") + " / 100", text_color=C_TEXT, text_size=size.small)

    table.cell(dash, 0, 2, "Supertrend",   text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(stScore),  text_color=cellOf(stScore, wST),  text_size=size.small)

    table.cell(dash, 0, 3, "EMA200",       text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(emaScore), text_color=cellOf(emaScore, wEMA), text_size=size.small)

    table.cell(dash, 0, 4, "RSI",          text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(rsiScore) + "  (" + str.tostring(rsiVal, "#.0") + ")", text_color=cellOf(rsiScore, wRSI), text_size=size.small)

    table.cell(dash, 0, 5, "ADX",          text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(adxScore) + "  (" + str.tostring(adxVal, "#.0") + ")", text_color=cellOf(adxScore, wADX), text_size=size.small)

    table.cell(dash, 0, 6, "HTF",          text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(htfScore), text_color=cellOf(htfScore, wHTF), text_size=size.small)

    table.cell(dash, 0, 7, "S/R",          text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(srScore),  text_color=cellOf(srScore, wSR),  text_size=size.small)

    table.cell(dash, 0, 8, "Ribbon",        text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(ribScore), text_color=cellOf(ribScore, wRIB), text_size=size.small)

    table.cell(dash, 0, 9, "Structure",    text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1, 9, str.tostring(strScore), text_color=cellOf(strScore, wSTR), text_size=size.small)

    table.cell(dash, 0,10, "Sweep",        text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1,10, str.tostring(swpScore), text_color=cellOf(swpScore, wSWP), text_size=size.small)

    table.cell(dash, 0,11, "Vol bonus",    text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1,11, str.tostring(volBonus) + "  (" + str.tostring(atrPct, "#.00") + "%)", text_color=C_TEXT, text_size=size.small)

    table.cell(dash, 0,12, "Room R",       text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1,12, str.tostring(dRes, "#.00") + " ATR", text_color=C_TEXT, text_size=size.small)

    table.cell(dash, 0,13, "Room S",       text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1,13, str.tostring(dSup, "#.00") + " ATR", text_color=C_TEXT, text_size=size.small)

    table.cell(dash, 0,14, "Suggested",    text_color=C_LABEL, text_size=size.small)
    table.cell(dash, 1,14, "SL " + str.tostring(sl, format.mintick) + " · TP " + str.tostring(tp, format.mintick), text_color=C_TEXT, text_size=size.small)

// ─── Alerts (server-compatible JSON) ───────────────────────────────────
// Mirrors `models.TVSignal`. Send to your /webhook with HMAC if you want.
buildAlertJson(string sideStr, string gradeStr) =>
    "{" +
     "\"strategy\":\"QMIE-Visualizer\"," +
     "\"event\":\"entry\"," +
     "\"symbol\":\""        + syminfo.ticker + "\"," +
     "\"asset_class\":\"CRYPTO\"," +
     "\"timeframe\":\""     + timeframe.period + "\"," +
     "\"side\":\""          + sideStr + "\"," +
     "\"signal_price\":"    + str.tostring(close) + "," +
     "\"stop_loss\":"       + str.tostring(sl) + "," +
     "\"take_profit\":"     + str.tostring(tp) + "," +
     "\"score\":"           + str.tostring(score, "#.0") + "," +
     "\"grade\":\""         + gradeStr + "\"," +
     "\"trend\":\""         + (sideStr == "BUY" ? "bullish" : "bearish") + "\"," +
     "\"htf\":\""           + (htfD != 0 ? "aligned" : "neutral") + "\"," +
     "\"adx\":"             + str.tostring(adxVal, "#.00") + "," +
     "\"atr\":"             + str.tostring(atrVal, "#.0000") + "," +
     "\"timestamp\":\""     + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ssZ", "UTC") + "\"," +
     "\"bar_time\":"        + str.tostring(time) +
     "}"

if emitAlert and barstate.isconfirmed and isFreshBuy
    alert(buildAlertJson("BUY", grade), alert.freq_once_per_bar_close)
if emitAlert and barstate.isconfirmed and isFreshSell
    alert(buildAlertJson("SELL", grade), alert.freq_once_per_bar_close)
