# ════════════════════════════════════════════════════════════════════════
#  QMIE Scanner — Environment Configuration
#  Copy to `.env` and fill in. Never commit secrets.
# ════════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
WORKERS=1
ENV=production

# ─── Webhook (optional ingress for Pine visualizer alerts) ──────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=replace_me_with_64_hex_chars
WEBHOOK_REQUIRE_HMAC=true
WEBHOOK_MAX_AGE_SEC=60
WEBHOOK_ALLOW_IPS=

# ─── Storage ────────────────────────────────────────────────────────────
DB_URL=sqlite+aiosqlite:///./data/qmie.db
# Optional Redis for cross-restart dedup (highly recommended in prod)
# REDIS_URL=redis://redis:6379/0
DEDUP_TTL_SEC=1800

# ─── Notifiers ──────────────────────────────────────────────────────────
DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY
DISCORD_USERNAME=QMIE
DISCORD_AVATAR_URL=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Scanner ────────────────────────────────────────────────────────────
# Data source: binance | bybit
SCAN_DATA_SOURCE=binance
SCAN_DATA_TIMEOUT_SEC=10.0
SCAN_MAX_CONCURRENCY=8

# Static symbol list (USDT-margined perps).
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,MATICUSDT,DOTUSDT,LTCUSDT,TRXUSDT,ATOMUSDT,NEARUSDT,APTUSDT,ARBUSDT,OPUSDT,SUIUSDT,INJUSDT,FILUSDT,RNDRUSDT,TIAUSDT,SEIUSDT,ORDIUSDT,WLDUSDT,FETUSDT,1000PEPEUSDT,BONKUSDT,PYTHUSDT

# Auto-discover top-N by 24h volume in addition to the static list.
# 0 = static only.
SCAN_AUTO_UNIVERSE_TOP_N=0
SCAN_MIN_24H_QUOTE_VOLUME=50000000

# Timeframes to scan. Each fires once per closed bar.
SCAN_TIMEFRAMES=1h,4h
SCAN_LOOP_INTERVAL_SEC=30

# Higher-timeframe map for HTF confirmation (scan_tf:htf,...)
SCAN_HTF_MAP=15m:1h,1h:4h,4h:1d,1d:1w

# Min grade to ALERT on. A+ | A | B | C | REJECT
SCAN_MIN_ALERT_GRADE=A

# ─── Signal weights (sum = 100) ─────────────────────────────────────────
W_SUPERTREND=20
W_EMA=15
W_RSI=15
W_ADX=15
W_HTF=20
W_SR=10
W_VOL=5

# ─── Volatility filter ──────────────────────────────────────────────────
SIG_MIN_ATR_PCT=0.10
SIG_MAX_ATR_PCT=8.0
SIG_MAX_SIGNALS_PER_SYMBOL_PER_DAY=4

# ─── TradingView deep-link prefix ───────────────────────────────────────
# BINANCE shows USDT perps. Use BYBIT if you scan via bybit and want
# the deep-link to land on Bybit data.
TV_CHART_PREFIX=BINANCE
